# Polymarket
POLYGON_PRIVATE_KEY=0x_your_private_key_here
POLYGON_WALLET_ADDRESS=0x_your_wallet_address_here
# Comma-separated watched wallet addresses. Use `uv run resolve-wallet` or
# `uv run rank-copytrade-wallets` to build this list.
WATCHED_WALLETS=

# Trading mode
USE_REAL_MONEY=false

# Risk parameters
MAX_BET_FRACTION=0.04
MIN_CONFIDENCE=0.55
MIN_BET_USD=1.00
ALLOWED_ENTRY_PRICE_BANDS=
ALLOWED_TIME_TO_CLOSE_BANDS=
ALLOW_HEURISTIC=true
HEURISTIC_MIN_ENTRY_PRICE=0.65
HEURISTIC_MAX_ENTRY_PRICE=0.75
HEURISTIC_ALLOWED_ENTRY_PRICE_BANDS=
HEURISTIC_MIN_TIME_TO_CLOSE=0s
ALLOW_XGBOOST=true
XGBOOST_ALLOWED_ENTRY_PRICE_BANDS=
MODEL_MIN_TIME_TO_CLOSE=0s
SHADOW_BANKROLL_USD=3000
TRADE_LOG_ARCHIVE_ENABLED=true
TRADE_LOG_ARCHIVE_MIN_AGE_DAYS=30
TRADE_LOG_ARCHIVE_BATCH_ROWS=10000
TRADE_LOG_ARCHIVE_VACUUM=true
MAX_LIVE_DRAWDOWN_PCT=0.08
MAX_DAILY_LOSS_PCT=0.05
STOP_LOSS_ENABLED=true
STOP_LOSS_MAX_LOSS_PCT=0.15
STOP_LOSS_MIN_HOLD=20m
MAX_TOTAL_OPEN_EXPOSURE_FRACTION=0.25
MAX_MARKET_EXPOSURE_FRACTION=0.10
MAX_TRADER_EXPOSURE_FRACTION=0.10
MAX_LIVE_HEALTH_FAILURES=3
LIVE_REQUIRE_SHADOW_HISTORY=true
LIVE_MIN_SHADOW_RESOLVED=100
LIVE_MIN_SHADOW_RESOLVED_SINCE_PROMOTION=0
REPLAY_SEARCH_BASE_POLICY_FILE=replay_search_specs/base_policy.json
REPLAY_SEARCH_GRID_FILE=replay_search_specs/grid.json
REPLAY_SEARCH_CONSTRAINTS_FILE=replay_search_specs/constraints.json
REPLAY_SEARCH_SCORE_WEIGHTS_FILE=replay_search_specs/score_weights.json
REPLAY_SEARCH_WINDOW_DAYS=14
REPLAY_SEARCH_WINDOW_COUNT=6
REPLAY_SEARCH_SCHEDULE_HOUR_LOCAL=5
REPLAY_AUTO_PROMOTE_ENABLED=true
REPLAY_AUTO_PROMOTE_MIN_SCORE_DELTA=0.0

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard API
# Leave 127.0.0.1 for same-machine use. Set 0.0.0.0 to allow a dashboard on another machine.
DASHBOARD_API_HOST=127.0.0.1
DASHBOARD_API_PORT=8765
# Optional bearer token required by the dashboard when set.
DASHBOARD_API_TOKEN=
# Public URL that Telegram /link should return for the web dashboard.
# On Tailscale, use your MagicDNS name, for example:
# http://windows-box.tailnet-name.ts.net:8765
DASHBOARD_WEB_URL=

# Dashboard client
# Set these on the machine running only the dashboard. Useful for Tailscale, for example:
# KELLY_API_BASE_URL=http://100.x.y.z:8765 or http://windows-box.tailnet-name.ts.net:8765
KELLY_API_BASE_URL=http://127.0.0.1:8765
KELLY_API_TOKEN=

# System
POLL_INTERVAL_SECONDS=1
HOT_WALLET_COUNT=16
WARM_WALLET_COUNT=24
WARM_POLL_INTERVAL_MULTIPLIER=5
DISCOVERY_POLL_INTERVAL_MULTIPLIER=20
WALLET_DISCOVERY_ENABLED=true
WALLET_DISCOVERY_SCAN_INTERVAL=6h
WALLET_DISCOVERY_LEADERBOARD_PAGES=2
WALLET_DISCOVERY_LEADERBOARD_PER_PAGE=25
WALLET_DISCOVERY_ANALYZE_LIMIT=40
WALLET_DISCOVERY_CANDIDATE_LIMIT=20
WALLET_INACTIVITY_LIMIT=unlimited
WALLET_SLOW_DROP_MAX_TRACKING_AGE=unlimited
WALLET_PERFORMANCE_DROP_MIN_TRADES=40
WALLET_PERFORMANCE_DROP_MAX_WIN_RATE=0.40
WALLET_PERFORMANCE_DROP_MAX_AVG_RETURN=-0.03
WALLET_UNCOPYABLE_PENALTY_MIN_BUYS=12
WALLET_UNCOPYABLE_PENALTY_WEIGHT=0.25
WALLET_UNCOPYABLE_DROP_MIN_BUYS=24
WALLET_UNCOPYABLE_DROP_MAX_SKIP_RATE=0.75
WALLET_UNCOPYABLE_DROP_MAX_RESOLVED_COPIED=3
MAX_SOURCE_TRADE_AGE=90s
MAX_SOURCE_LATENCY=5s
MAX_FEED_STALENESS=90s
MIN_EXECUTION_WINDOW=45s
MAX_MARKET_HORIZON=3d
WALLET_COLD_START_MIN_OBSERVED_BUYS=3
WALLET_DISCOVERY_MIN_OBSERVED_BUYS=8
WALLET_DISCOVERY_MIN_RESOLVED_BUYS=3
WALLET_DISCOVERY_SIZE_MULTIPLIER=0.20
WALLET_TRUSTED_MIN_RESOLVED_COPIED_BUYS=15
WALLET_PROBATION_SIZE_MULTIPLIER=0.50
WALLET_LOCAL_PERFORMANCE_PENALTY_MIN_RESOLVED_COPIED_BUYS=15
WALLET_LOCAL_PERFORMANCE_PENALTY_MAX_AVG_RETURN=-0.10
WALLET_LOCAL_PERFORMANCE_PENALTY_SIZE_MULTIPLIER=0.25
WALLET_QUALITY_SIZE_MIN_MULTIPLIER=0.75
WALLET_QUALITY_SIZE_MAX_MULTIPLIER=1.25
RETRAIN_BASE_CADENCE=daily
RETRAIN_HOUR_LOCAL=3
RETRAIN_EARLY_CHECK_INTERVAL=24h
RETRAIN_MIN_NEW_LABELS=100
RETRAIN_MIN_SAMPLES=200
REPLAY_SEARCH_BASE_CADENCE=daily
REPLAY_SEARCH_HOUR_LOCAL=5
REPLAY_SEARCH_LABEL_PREFIX=scheduled
REPLAY_SEARCH_TOP=10
REPLAY_SEARCH_MAX_COMBOS=256
REPLAY_AUTO_PROMOTE=true
REPLAY_AUTO_PROMOTE_MIN_PNL_DELTA_USD=0
LOG_LEVEL=INFO
MODEL_PATH=save/model.joblib
